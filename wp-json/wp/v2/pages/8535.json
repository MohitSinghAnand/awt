e costs also depend on the season and the distance from the capital island, Male.                      <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>How does visa processing work for Maldives? <\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        Indians do not need a pre-arrival visa for tourism, provided they have a valid passport and proper travel documents, including accommodation booking evidence, sufficient funds, etc. Tourist visas are valid for 90 days.                      <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>Do you need a passport to visit the Maldives? <\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        Yes, you will need a valid passport to visit Maldives.                     <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>How much does it cost to explore the Maldives? <\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        The cost of Maldives tour packages depends on many factors, including the resort chosen, the season you are visiting, activities chosen, the places you visit, and the tour operator. At ATW Travels, you can book 3Nights 4Days Maldives tour packages at less than INR 25,000.                      <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>How many days do you need to explore the Maldives? <\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        While the island country has over 1000 islands, only 200 are habitable. To explore the entire country, 4-5 days are enough. But if you plan to explore all the various activities the resorts offer, you will need around a week.                      <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>Can you take babies to the Maldives? <\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        Maldivians are warm, friendly, and happy to help couples traveling with babies. You can even hire a babysitter on the resort if you plan a romantic date with your loved one. Before booking a package, ensure the resort allows kids as most water villas have age restrictions.                      <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>Do you have to pay tips in the Maldives?<\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        Tipping is uncommon in the Maldives. Most hotels and restaurants do not encourage tipping, as a 10% service tax is always added to the bill. But it is up to you to tip, depending on the quality of service you were provided.                      <\/div>\r\n                <\/div>\r\n                            <\/div>\r\n[\/vc_column][\/vc_row][vc_row disable_element=&#8221;yes&#8221; el_id=&#8221;book_div_section&#8221; el_class=&#8221;float-left mob-m0&#8243;][vc_column][vc_empty_space height=&#8221;50px&#8221; css=&#8221;.vc_custom_1683093603280{margin-bottom: 0px !important;}&#8221;][\/vc_column][\/vc_row][vc_row full_width=&#8221;stretch_row_content_no_spaces&#8221; equal_height=&#8221;yes&#8221; el_id=&#8221;homebooking&#822