a-anim=\"adpr:false;\" data-in=\"o:0;\" data-out=\"a:false;\">\n\t\t\t\t\t\t\t<img decoding=\"async\" src=\"\/\/www.atwtravels.com\/wp-content\/plugins\/revslider\/public\/assets\/assets\/dummy.png\" alt=\"nayan wikki gtholidays feedback\" title=\"nayan wikki gtholidays feedback\" width=\"1920\" height=\"768\" class=\"rev-slidebg tp-rs-img rs-lazyload\" data-lazyload=\"\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/05\/nayan-wikki-gtholidays-feedback.jpg\" data-bg=\"f:contain;\" data-no-retina>\n<!---->\t\t\t\t\t\t<\/rs-slide>\n\t\t\t\t\t\t<rs-slide style=\"position: absolute;\" data-key=\"rs-9\" data-title=\"Slide\" data-thumb=\"\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/05\/ceo-watertec-gtholidays-feedback-50x100.jpg\" data-anim=\"adpr:false;\" data-in=\"o:0;\" data-out=\"a:false;\">\n\t\t\t\t\t\t\t<img decoding=\"async\" src=\"\/\/www.atwtravels.com\/wp-content\/plugins\/revslider\/public\/assets\/assets\/dummy.png\" alt=\"\" title=\"ceo watertec gtholidays feedback\" width=\"1920\" height=\"768\" class=\"rev-slidebg tp-rs-img rs-lazyload\" data-lazyload=\"\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/05\/ceo-watertec-gtholidays-feedback.jpg\" data-bg=\"f:contain;\" data-no-retina>\n<!---->\t\t\t\t\t\t<\/rs-slide>\n\t\t\t\t\t<\/rs-slides>\n\t\t\t\t<\/rs-module>\n\t\t\t\t<script>\n\t\t\t\t\tsetREVStartSize({c: 'rev_slider_2_1',rl:[1240,1024,778,480],el:[768],gw:[1920],gh:[768],type:'standard',justify:'',layout:'fullwidth',mh:\"0\"});if (window.RS_MODULES!==undefined && window.RS_MODULES.modules!==undefined && window.RS_MODULES.modules[\"revslider21\"]!==undefined) {window.RS_MODULES.modules[\"revslider21\"].once = false;window.revapi2 = undefined;if (window.RS_MODULES.checkMinimal!==undefined) window.RS_MODULES.checkMinimal()}\n\t\t\t\t<\/script>\n\t\t\t<\/rs-module-wrap>\n\t\t\t<!-- END REVOLUTION SLIDER -->\n[\/vc_column][\/vc_row][vc_row disable_element=&#8221;yes&#8221;][vc_column]<div class=\"st-testimonial-new style-1 \">\r\n                <p class=\"gth_testimonial_heading\">Our happy clients<\/p>\r\n        <div class=\"owl-carousel st-testimonial-slider style-1 \">                <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/08\/Sylvia-Das-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Sylvia Das<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        Do you want to travel but don\u2019t want to go through the bother of finding plane tickets, cruises, tours and so forth on your own? Would you like professional help to ensure you\u2019re getting the best deal? Would you like someone with lots of experience to help you avoid the typical tourist traps and discover somewhere special?\nIf you answered \u201cyes\u201d to any of these questions, ATW Travels. Is the right place for you!                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/08\/Pappichettiar-Gandhi-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Pappichettiar Gandhi<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        Good planning of tours, guides at destinations. This would easy our tension. Arrangements as per itinerary. Agencies in abroad very attentive and reachable. In our Bangkok and Phuket program from Coimbatore we are very much satisfied. We recommend GT travels.                     <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Raji-Viswanathan-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Raji Viswanathan<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        For Coimbatore Branch - Excellent service and promising words.. They have great Patience level nd the follow up made to make arrangements was very helpful to us. Kalpana before the trip and Nishant during the trip made 100% sure that our expectations are met. Thank you GT for giving us a memorable trip for lifetime.                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Lokesh-Abinav-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Lokesh Abinav<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        Picked and gave the best plan for us thanks to Nishanth from ATW Travels all the arrangements were good hotel stay was excellent in mauritius made us a memorable trip                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Karthik-Muthuraj-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Karthik Muthuraj<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        We take great pleasure in thanking ATW Travels for offering an amazing international package. The tour was incredible and we had lot of fun! They offered us an excellent arrangement of hotel, food, transport and sightseeing tour. We will strongly recommend ATW Travels tours to all.... Thanks a lot....                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Anush-Kumar-Guru-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Anush Kumar Guru<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        Proud of Karthik Anna and ATW Travels.. Happy that it was found in the next room of mine in G3 hostel @ PSG Tech and has grown to this much height.. Keep doing the good job team.. \ud83d\ude42 All my supports are with you.. Keep us updated on the latest happenings of ATW Travels.. \ud83d\ude42                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Sathish-Kumar-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Sathish Kumar<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        One of the best travel company in Tamilnadu. Professional services and good customer relationship. Very friendly approach is seen with all the people handling there.                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Siva-Mani-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Siva Mani<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        We had an international tour to Europe with ATW Travels. It was handled by Erode branch and the trip was awesome and very well executed. Thank u and keep it up                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Sri-Ihigaa-Mushme-Thirugnanam-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Sri Ihigaa Mushme Thirugnanam<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        My family wanted to go on a trip to germany. We preferred ATW Travels for the package. We just told them the place and the rest they took care of it. The service was simply superb. Hotels we stayed were awesome. Food was really good and we enjoyed throughout....I wish them to maintain the same.                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Raja-Sehar-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Raja Sehar<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        With ATW Travels we went a tour for Andaman, they had arranged the facilities properly with good accommodations and travel.It was a nice trip. Also I would like to thank Rathinam and Vignesh for their service in coordinating with the people in Andaman and make the tour easy and happy. Thanks once again ATW Travels for their service.                    <\/p>\r\n                <\/div>\r\n                            <div class=\"item has-matchHeight\">\r\n                    <div class=\"author\">\r\n                                                <img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2020\/01\/Narendra-Lath-70x70.jpg\" alt=\"User Avatar\"\/>\r\n                        <div class=\"author-meta\">\r\n                            <p class=\"gth_testimonial_personName\">Narendra Lath<\/p>\r\n                            <div class=\"star\">\r\n                                <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i> <i class=\"fa fa-star\"><\/i>                             <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                    <p>\r\n                        Have been to two tours with ATW Travels - Bali and Armenia... Both have been well organised. The tour guides (Mr. Nilesh for Bali, and Mr. Livin for Armenia) were both great! They took great care for our comforts and every want\/need!                    <\/p>\r\n                <\/div>\r\n            <\/div><\/div>\r\n[\/vc_column][\/vc_row][vc_row][vc_column][vc_custom_heading text=&#8221;Our happy clients&#8221; font_container=&#8221;tag:h3|font_size:28px|text_align:left|color:%23000000&#8243; use_theme_fonts=&#8221;yes&#8221; css=&#8221;.vc_custom_1661759009170{margin-bottom: 35px !important;}&#8221;]<div class=\"carousel-slider-outer carousel-slider-outer-image-carousel carousel-slider-outer-26538\" style=\"--carousel-slider-nav-color:#f1f1f1;--carousel-slider-active-nav-color:#00d1b2;--carousel-slider-arrow-size:48px;--carousel-slider-bullet-size:10px\">\n<div id=\"&#039;id-26538\" class=\"carousel-slider carousel-slider-26538 arrows-visibility-hover dots-visibility-never arrows-outside dots-center dots-circle owl-carousel\" data-slide-type=\"image-carousel\" data-owl-settings='{\"nav\":true,\"dots\":false,\"slideBy\":1,\"stagePadding\":0,\"margin\":10,\"loop\":true,\"lazyLoad\":false,\"autoplay\":true,\"autoplayTimeout\":5000,\"autoplaySpeed\":500,\"autoplayHoverPause\":true,\"autoWid