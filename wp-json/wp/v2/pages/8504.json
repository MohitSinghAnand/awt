 sharing<\/p>\n<p>[\/vc_column_text][\/vc_column_inner][vc_column_inner el_class=&#8221;gt-book-section&#8221; width=&#8221;1\/2&#8243;][vc_btn title=&#8221;Book Now&#8221; style=&#8221;custom&#8221; custom_background=&#8221;#f99914&#8243; custom_text=&#8221;#212221&#8243; size=&#8221;sm&#8221; align=&#8221;center&#8221; button_block=&#8221;true&#8221; el_id=&#8221;gt-booking&#8221; el_class=&#8221;gt-theme-button&#8221;][vc_btn title=&#8221;View All Packages&#8221; style=&#8221;custom&#8221; custom_background=&#8221;#40e0d0&#8243; custom_text=&#8221;#ffffff&#8221; size=&#8221;sm&#8221; align=&#8221;center&#8221; button_block=&#8221;true&#8221; el_class=&#8221;gt-theme-button&#8221; link=&#8221;url:%23gt_all_packages&#8221;][\/vc_column_inner][\/vc_row_inner][\/vc_column][\/vc_row][vc_row][vc_column width=&#8221;2\/3&#8243;][vc_row_inner el_class=&#8221;gt-package-slider&#8221;][vc_column_inner][vc_images_carousel images=&#8221;30294,30295,30296,30297,30298,30299&#8243; img_size=&#8221;full&#8221; onclick=&#8221;link_no&#8221; autoplay=&#8221;yes&#8221; hide_pagination_control=&#8221;yes&#8221; wrap=&#8221;yes&#8221;][\/vc_column_inner][\/vc_row_inner][vc_row_inner el_class=&#8221;gt-slider-bottom-section&#8221;][vc_column_inner width=&#8221;3\/4&#8243;][vc_acf field_group=&#8221;29256&#8243; field_from_29256=&#8221;field_6458cb457e4af&#8221; show_label=&#8221;yes&#8221; el_class=&#8221;gt-acf-general&#8221;][vc_acf field_group=&#8221;29256&#8243; field_from_29256=&#8221;field_6458cb3a7e4ae&#8221; show_label=&#8221;yes&#8221; el_class=&#8221;gt-acf-general&#8221;][vc_acf field_group=&#8221;29256&#8243; field_from_29256=&#8221;field_6458cb2d7e4ad&#8221; show_label=&#8221;yes&#8221; el_class=&#8221;gt-acf-general&#8221;][\/vc_column_inner][vc_column_inner width=&#8221;1\/4&#8243;][vc_btn title=&#8221;View All Packages&#8221; style=&#8221;custom&#8221; custom_background=&#8221;#f99914&#8243; custom_text=&#8221;#212221&#8243; size=&#8221;sm&#8221; align=&#8221;center&#8221; button_block=&#8221;true&#8221; el_class=&#8221;gt-theme-button&#8221; link=&#8221;url:%23gt_all_packages&#8221;][\/vc_column_inner][\/vc_row_inner][\/vc_column][vc_column width=&#8221;1\/3&#8243;][vc_row_inner][vc_column_inner el_class=&#8221;gt-detail-table&#8221;][vc_custom_heading text=&#8221;South India\u2019s No.1 Travel Brand&#8221; font_container=&#8221;tag:h4|font_size:16px|text_align:left&#8221; use_theme_fonts=&#8221;yes&#8221;][vc_separator][vc_column_text el_class=&#8221;gt-detail-field&#8221;]<\/p>\n<div>Indonesian Rupiah<\/div>\n<div>Currency Name<\/div>\n<p>[\/vc_column_text][vc_column_text el_class=&#8221;gt-detail-field&#8221;]<\/p>\n<div>27\u00b0C to 32\u00b0C<\/div>\n<div>Climate in Bali<\/div>\n<p>[\/vc_column_text][vc_column_text el_class=&#8221;gt-detail-field&#8221;]<\/p>\n<div>April - October<\/div>\n<div>Best Season to Visit Bali<\/div>\n<p>[\/vc_column_text][vc_column_text el_class=&#8221;gt-detail-field&#8221;]<\/p>\n<div>Indonesian, Balinese, English<\/div>\n<div>Languages Speaking<\/div>\n<p>[\/vc_column_text][\/vc_column_inner][\/vc_row_inner][vc_row_inner][vc_column_inner el_class=&#8221;gt-tips-section&#8221;][vc_custom_heading text=&#8221;Essential Tips for Travelling to the Bali&#8221; font_container=&#8221;tag:h4|font_size:16px|text_align:left&#8221; use_theme_fonts=&#8221;yes&#8221;]        <div class=\"title-insta\">\r\n            <div class=\"st-img-icon\"><img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/11\/ATMs.png\" alt=\"\"><\/div>\r\n            <p class=\"text\">ATMs are readily accessible only in certain areas.<\/p>\r\n        <\/div>\r\n                <div class=\"title-insta\">\r\n            <div class=\"st-img-icon\"><img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/11\/Credit-Cards.png\" alt=\"\"><\/div>\r\n            <p class=\"text\">Credit Cards are widely accepted.<\/p>\r\n        <\/div>\r\n                <div class=\"title-insta\">\r\n            <div class=\"st-img-icon\"><img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/11\/Bank.png\" alt=\"\"><\/div>\r\n            <p class=\"text\">Seamless banking discovery in Bali.<\/p>\r\n        <\/div>\r\n                <div class=\"title-insta\">\r\n            <div class=\"st-img-icon\"><img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/11\/Drinking.png\" alt=\"\"><\/div>\r\n            <p class=\"text\">The legal drinking age in Bali is 18.<\/p>\r\n        <\/div>\r\n                <div class=\"title-insta\">\r\n            <div class=\"st-img-icon\"><img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/11\/Safest.png\" alt=\"\"><\/div>\r\n            <p class=\"text\">Balinese are celebrated for their friendliness.<\/p>\r\n        <\/div>\r\n                <div class=\"title-insta\">\r\n            <div class=\"st-img-icon\"><img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/11\/Weekend.png\" alt=\"\"><\/div>\r\n            <p class=\"text\">Bali has a Different Weekend: Friday and Saturday.<\/p>\r\n        <\/div>\r\n                <div class=\"title-insta\">\r\n            <div class=\"st-img-icon\"><img decoding=\"async\" src=\"https:\/\/www.atwtravels.com\/wp-content\/uploads\/2019\/11\/Prices.png\" alt=\"\"><\/div>\r\n            <p class=\"text\">Prices are typically cheaper in November to March.<\/p>\r\n        <\/div>\r\n        [\/vc_column_inner][\/vc_row_inner][\/vc_column][\/vc_row][vc_row el_class=&#8221;float-left&#8221; el_id=&#8221;gt_country_tour_details&#8221;][vc_column][vc_custom_heading text=&#8221;Bali &#8211; Visitors Statistics&#8221; use_theme_fonts=&#8221;yes&#8221;][vc_row_inner css=&#8221;.vc_custom_1683352016764{padding-top: 40px !important;}&#8221;][vc_column_inner el_class=&#8221;border-design-right gt-horizontal-map gt-statistics&#8221; width=&#8221;1\/4&#8243;][vc_single_image image=&#8221;30302&#8243; img_size=&#8221;full&#8221; alignment=&#8221;center&#8221;][\/vc_column_inner][vc_column_inner el_class=&#8221;border-design-right gt-statistics&#8221; width=&#8221;1\/4&#8243;][vc_custom_heading text=&#8221;Annually&#8221; font_container=&#8221;tag:h3|text_align:left&#8221; use_theme_fonts=&#8221;yes&#8221; el_class=&#8221;gt_statistics_heading_sub&#8221;][vc_column_text el_class=&#8221;tour_gt_number&#8221;]<span class=\"no_desig_gth\">49,00,000<\/span>[\/vc_column_text][vc_column_text el_class=&#8221;count_no_tour_people&#8221;]<\/p>\n<div class=\"list_gt_div\">\n<div class=\"gt_tour_male\">\n<p class=\"gth_tourm_head\"><span class=\"gth_count_he\">Male<\/span><span class=\"gth_countper\">51%<\/span><\/p>\n<\/div>\n<div class=\"gt_tour_fem\">\n<p class=\"gth_tourm_head\"><span class=\"gth_count_he\">Female<\/span><span class=\"gth_countper\">49%<\/span><\/p>\n<\/div>\n<\/div>\n<p>[\/vc_column_text][\/vc_column_inner][vc_column_inner el_class=&#8221;border-design-right gt-statistics&#8221; width=&#8221;1\/4&#8243;][vc_custom_heading text=&#8221;By Purpose&#8221; font_container=&#8221;tag:h3|text_align:left&#8221; use_theme_fonts=&#8221;yes&#8221; el_class=&#8221;gt_statistics_heading_sub&#8221;][vc_column_text el_class=&#8221;purpose_div&#8221;]<\/p>\n<div class=\"gthpurpose\">\n<div class=\"gthpurpose-img\"><img decoding=\"async\" src=\"\/wp-content\/uploads\/2019\/11\/gt-hoildays-couple-icon.png\" alt=\"tour package tourism\" \/><\/div>\n<div class=\"gthpurpose-block\">\n<p class=\"gthpurpose-title\">Couples<\/p>\n<p class=\"gthpurpose-text\">For Newlywed Vacations<\/p>\n<div class=\"progress\">\n<div class=\"progress-bar\" style=\"width: 55%;\"><\/div>\n<\/div>\n<\/div>\n<\/div>\n<p>[\/vc_column_text][vc_column_text el_class=&#8221;purpose_div&#8221;]<\/p>\n<div class=\"gthpurpose\">\n<div class=\"gthpurpose-img\"><img decoding=\"async\" src=\"\/wp-content\/uploads\/2019\/11\/gt-hoildays-family-icon.png\" alt=\"tour packages business\" \/><\/div>\n<div class=\"gthpurpose-block\">\n<p class=\"gthpurpose-title\">Family<\/p>\n<p class=\"gthpurpose-text\">For Family Vacations<\/p>\n<div class=\"progress\">\n<div class=\"progress-bar\" style=\"width: 35%;\"><\/div>\n<\/div>\n<\/div>\n<\/div>\n<p>[\/vc_column_text][\/vc_column_inner][vc_column_inner el_class=&#8221;gt-statistics&#8221; width=&#8221;1\/4&#8243;][vc_custom_heading text=&#8221;Top Visitors from India&#8221; font_container=&#8221;tag:h3|text_align:left&#8221; use_theme_fonts=&#8221;yes&#8221; el_class=&#8221;gt_statistics_heading_sub&#8221;][vc_column_text]<\/p>\n<div class=\"gt-top-city\">\n<p class=\"gt-top-city-list\">Bengaluru<\/p>\n<p class=\"gt-top-city-list\">Mumbai<\/p>\n<p class=\"gt-top-city-list\">India<\/p>\n<p class=\"gt-top-city-list\">Delhi<\/p>\n<p class=\"gt-top-city-list\">Hyderabad<\/p>\n<p class=\"gt-top-city-list\">Pune<\/p>\n<p class=\"gt-top-city-list\">Kolkata<\/p>\n<p class=\"gt-top-city-list\">Ahmedabad<\/p>\n<p class=\"gt-top-city-list\">Jaipur<\/p>\n<p class=\"gt-top-city-list\">Lucknow<\/p>\n<\/div>\n<p>[\/vc_column_text][\/vc_column_inner][\/vc_row_inner][\/vc_column][\/vc_row][vc_row disable_element=&#8221;yes&#8221; css=&#8221;.vc_custom_1702387361144{margin-top: 20px !important;}&#8221; el_class=&#8221;float-left mob-m0&#8243; el_id=&#8221;package_div_section&#8221;][vc_column][vc_custom_heading text=&#8221;All You Need to Know About Bali Tour&#8221; use_theme_fonts=&#8221;yes&#8221;][\/vc_column][vc_column][vc_btn title=&#8221;Read More&#8221; align=&#8221;center&#8221; el_class=&#8221;readmoreBtn&#8221;][\/vc_column][\/vc_row][vc_row disable_element=&#8221;yes&#8221; el_id=&#8221;readmoreLayer&#8221;][vc_column][vc_row_inner el_class=&#8221;hide_readless&#8221;][vc_column_inner][\/vc_column_inner][\/vc_row_inner][vc_row_inner disable_element=&#8221;yes&#8221;][vc_column_inner width=&#8221;1\/3&#8243;][vc_column_text]  <div class=\"video-popup\" id=\"video-popup1\" style=\"background-image: url(