9t.                    <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>How do I book a venue or resort for destination wedding?<\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        ATW Travels has a list of gorgeous destination wedding locations in Andaman for couples to choose from. Regardless of whichever venue or resort you want to book, we will handle all the bookings for you. Depending on what you have chosen from our Andaman destination wedding packages, we can assign the resort or venue for you.                    <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>Do you organize just weddings or other events as well?<\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        We organize other wedding events as well along with the actual wedding, such as the Mehendi, sangeet, and so on. Therefore, we can tailor your package accordingly.                    <\/div>\r\n                <\/div>\r\n                                <div class=\"item \">\r\n                    <div class=\"header\">\r\n                        <i class=\"input-icon field-icon fa\"><svg height=\"18px\" width=\"18px\" version=\"1.1\" id=\"Layer_1\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" xmlns:xlink=\"http:\/\/www.w3.org\/1999\/xlink\" x=\"0px\" y=\"0px\"\r\n     viewBox=\"0 0 24 24\" style=\"enable-background:new 0 0 24 24;\" xml:space=\"preserve\">\r\n\r\n<g fill=\"#5E6D77\">\r\n    <path d=\"M5.25,24c-0.116,0-0.232-0.027-0.336-0.079C4.659,23.793,4.5,23.536,4.5,23.25V19.5H2.25C1.009,19.5,0,18.491,0,17.25v-15\r\n        C0,1.009,1.009,0,2.25,0h19.5C22.991,0,24,1.009,24,2.25v15c0,1.241-1.009,2.25-2.25,2.25H11.5l-5.8,4.35\r\n        C5.571,23.947,5.411,24,5.25,24z M2.25,1.5C1.836,1.5,1.5,1.836,1.5,2.25v15C1.5,17.664,1.836,18,2.25,18h3\r\n        C5.664,18,6,18.336,6,18.75v3l4.8-3.6c0.129-0.097,0.289-0.15,0.45-0.15h10.5c0.414,0,0.75-0.336,0.75-0.75v-15\r\n        c0-0.414-0.336-0.75-0.75-0.75H2.25z\"\/>\r\n    <path d=\"M12,12c-0.414,0-0.75-0.336-0.75-0.75v-0.256c-0.001-0.952,0.602-1.805,1.5-2.122c0.897-0.317,1.5-1.17,1.5-2.121\r\n        c0-0.6-0.234-1.165-0.66-1.59c-0.425-0.426-0.99-0.66-1.59-0.66c-0.601,0-1.166,0.234-1.591,0.659\r\n        C9.984,5.584,9.75,6.149,9.75,6.75C9.75,7.164,9.414,7.5,9,7.5S8.25,7.163,8.25,6.75c0-2.067,1.683-3.749,3.75-3.749\r\n        c1.002,0,1.944,0.39,2.652,1.099c0.708,0.709,1.098,1.65,1.098,2.652c0,1.586-1.005,3.006-2.5,3.535\r\n        c-0.299,0.106-0.5,0.39-0.5,0.708v0.256C12.75,11.664,12.414,12,12,12z\"\/>\r\n    <circle cx=\"12\" cy=\"14.625\" r=\"1.125\"\/>\r\n<\/g>\r\n<\/svg><\/i>                        <h5>Is a destination wedding safe during the pandemic?<\/h5>\r\n                        <span class=\"arrow\">\r\n                            <i class=\"fa fa-angle-down\"><\/i>\r\n                        <\/span>\r\n                    <\/div>\r\n                    <div class=\"body\">\r\n                        When organized well, a destination wedding can indeed be safe during the pandemic as well. We at ATW Travels ensure that all the proper safety guidelines are taken care of and the safety protocols are followed by the guests as well as the staff members.                    <\/div>\r\n                <\/div>\r\n                            <\/div>\r\n[\/vc_column][\/vc_row][vc_row][vc_column][vc_widget_sidebar sidebar_id=&#8221;slider-sidebar&#8221;][\/vc_column][\/vc_row][vc_row el_class=&#8221;show-mobile contact_bg&#8221;][vc_column][vc_column_text css=&#8221;.vc_custom_1646499208348{margin-bottom: 0px !important;}&#8221;]<span class=\"form-head\">Get the Guaranteed Best Vacation Deals from ATW Travels<\/span>[\/vc_column_text]<div class=\"wpforms-container wpforms-container-full\" id=\"wpforms-28929\"><form id=\"wpforms-form-28929\" class=\"wpforms-validate wpforms-form wpforms-ajax-form\" data-formid=\"28929\" method=\"post\" enctype=\"multipart\/form-data\" action=\"\/wp-json\/wp\/v2\/pages\/14958\" data-token=\"d873e387c137d5231cfb9920ec563e1f\"><noscript class=\"wpforms-error-noscript\">Please enable JavaScript in your browser to complete this form.<\/noscript><div class=\"wpforms-field-container\"><div id=\"wpforms-28929-field_1-container\" class=\"wpforms-field wpforms-field-text\" data-field-id=\"1\"><label class=\"wpforms-field-label wpforms-label-hide\" for=\"wpforms-28929-field_1\">N